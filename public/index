<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Исправленный CSP: разрешаем загрузку со всех нужных доменов -->
    <meta http-equiv="Content-Security-Policy" content="
    default-src 'self' https:; 
    script-src 'self' 'unsafe-inline' 'unsafe-eval' https://api-maps.yandex.ru https://yastatic.net https://unpkg.com; 
    img-src 'self' data: https://*.yandex.net https://*.tile.openstreetmap.org https://unpkg.com https://cdn-icons-png.flaticon.com; 
    style-src 'self' 'unsafe-inline' https://unpkg.com; 
    connect-src 'self' https://*.yandex.ru; 
    frame-src https://*.yandex.ru;">

    <title>Balloon Service - Yandex Satellite</title>
    
    <!-- ПОЛНЫЕ ССЫЛКИ НА LEAFLET -->
    <link rel="stylesheet" href="https://unpkg.com" />
    <script src="https://unpkg.com"></script>
    
    <!-- ПОЛНАЯ ССЫЛКА НА API ЯНДЕКСА -->
    <script src="https://yandex.ru" type="text/javascript"></script>
    
    <!-- Локальный плагин (убедитесь, что файл Yandex.js лежит рядом с этим html) -->
    <script src="Yandex.js"></script>

    <style>
        #map { height: 100vh; width: 100%; background: #222; }
        body { margin: 0; padding: 0; overflow: hidden; }
        .info-panel {
            position: absolute; top: 10px; left: 50px; z-index: 1000;
            background: rgba(255, 255, 255, 0.9); padding: 10px;
            border-radius: 5px; font-family: Arial, sans-serif;
            box-shadow: 0 0 10px rgba(0,0,0,0.3);
        }
    </style>
</head>
<body>

    <div class="info-panel" id="info">
        <b>Статус:</b> Загрузка карты...<br>
        <b>Ветер:</b> <span id="wind-info">0 м/с</span>
    </div>
    <div id="map"></div>

    <script>
        // Ждем загрузки API Яндекса и DOM
        window.onload = function() {
            try {
                // 1. Инициализация слоя Яндекса
                const yandexLayer = new L.Yandex('hybrid'); // Гибрид (спутник + подписи)

                const map = L.map('map', {
                    center: [53.9, 27.5], 
                    zoom: 6,
                    layers: [yandexLayer]
                });

                L.control.layers({
                    "Яндекс Спутник": yandexLayer,
                    "OpenStreetMap": L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png')
                }).addTo(map);

                // 2. Иконка шара (заменил на прямую ссылку на картинку)
                const balloonIcon = L.icon({
                iconUrl: 'https://githubusercontent.com',
                iconSize: [50, 50],    // Размер иконки в пикселях
                iconAnchor: [25, 50],  // Точка привязки (низ центра иконки)
                popupAnchor: [0, -50]  // Где будет всплывать окно (если добавите)
                });

                let balloonMarker = L.marker([53.9, 27.5], { icon: balloonIcon }).addTo(map);

                // 3. Данные о ветре
                let windData = { speed: 8, deg: 225 }; 

                // 4. Функция движения
                function updateBalloonPosition() {
                    const currentPos = balloonMarker.getLatLng();
                    const meterToDegree = 0.00001; 
                    const angleRad = (windData.deg - 90) * (Math.PI / 180);

                    const deltaLat = Math.cos(angleRad) * windData.speed * meterToDegree;
                    const deltaLng = Math.sin(angleRad) * windData.speed * meterToDegree;

                    const newLat = currentPos.lat - deltaLat;
                    const newLng = currentPos.lng + deltaLng;

                    balloonMarker.setLatLng([newLat, newLng]);
                    
                    document.getElementById('wind-info').innerText = `${windData.speed} м/с, ${windData.deg}°`;
                    document.getElementById('info').innerHTML = `<b>Координаты:</b> ${newLat.toFixed(4)}, ${newLng.toFixed(4)}<br><b>Ветер:</b> ${windData.speed} м/с`;
                }

                setInterval(updateBalloonPosition, 1000);

            } catch (e) {
                console.error("Ошибка инициализации карты:", e);
                document.getElementById('info').innerHTML = "<b style='color:red'>Ошибка загрузки API Яндекса</b>";
            }
        };
    </script>
</body>
</html>
