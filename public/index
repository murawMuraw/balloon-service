<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Настройка безопасности: разрешаем работу Яндекса и Leaflet -->
    <meta http-equiv="Content-Security-Policy" content="
    default-src 'self' https:; 
    script-src 'self' 'unsafe-inline' 'unsafe-eval' https://yandex.ru https://yastatic.net https://unpkg.com; 
    img-src 'self' data: https://*.yandex.net https://*.tile.openstreetmap.org https://unpkg.com https://githubusercontent.com; 
    style-src 'self' 'unsafe-inline' https://unpkg.com; 
    connect-src 'self' https://*.yandex.ru; 
    frame-src https://*.yandex.ru;">

    <title>Balloon Service - Yandex Satellite</title>
    
    <!-- Подключаем стили и скрипты Leaflet -->
    <link rel="stylesheet" href="https://unpkg.com" />
    <script src="https://unpkg.com"></script>
    
    <!-- Подключаем API Яндекс.Карт с вашим ключом -->
    <script src="https://yandex.ru/2.1/?lang=ru_RU&apikey=57d7c8df-9f77-445d-8d31-b78bbd0a09b3" type="text/javascript"></script>
    
    <!-- Ваш локальный файл-адаптер -->
    <script src="Yandex.js"></script>

    <style>
        #map { height: 100vh; width: 100%; background: #1a1a1a; }
        body { margin: 0; padding: 0; overflow: hidden; }
        .info-panel {
            position: absolute; top: 15px; left: 60px; z-index: 1000;
            background: rgba(255, 255, 255, 0.95); padding: 12px;
            border-radius: 8px; font-family: 'Segoe UI', Tahoma, sans-serif;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            min-width: 200px;
        }
    </style>
</head>
<body>

    <div class="info-panel" id="info">
        <b>Статус:</b> Загрузка систем...<br>
        <b>Ветер:</b> <span id="wind-info">ожидание...</span>
    </div>
    <div id="map"></div>

    <script>
        window.onload = function() {
            try {
                // 1. Создаем слой Спутника Яндекса (Гибрид)
                const yandexLayer = new L.Yandex('hybrid'); 

                const map = L.map('map', {
                    center: [53.9, 27.5], 
                    zoom: 7,
                    layers: [yandexLayer]
                });

                // Добавляем выбор между Спутником и обычной картой
                L.control.layers({
                    "Яндекс Спутник": yandexLayer,
                    "OpenStreetMap": L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png')
                }).addTo(map);

                // 2. Настройка вашей иконки из GitHub (используем images/balloon.png если файл на сервере)
                const balloonIcon = L.icon({
                    iconUrl: 'images/balloon.png', 
                    iconSize: [50, 65],     // Размер иконки
                    iconAnchor: [25, 65]    // Точка привязки (низ центра)
                });

                // Создаем маркер шара
                let balloonMarker = L.marker([53.9, 27.5], { icon: balloonIcon }).addTo(map);

                // 3. Параметры ветра (можно будет менять динамически)
                let windData = { speed: 10, deg: 240 }; 

                // 4. Функция полета
                function updateBalloonPosition() {
                    const currentPos = balloonMarker.getLatLng();
                    
                    // Математика смещения (10 м/с ~ 0.0001 градуса за тик)
                    const factor = 0.00001; 
                    const rad = (windData.deg - 90) * (Math.PI / 180);

                    const dLat = Math.cos(rad) * windData.speed * factor;
                    const dLng = Math.sin(rad) * windData.speed * factor;

                    const newLat = currentPos.lat - dLat;
                    const newLng = currentPos.lng + dLng;

                    balloonMarker.setLatLng([newLat, newLng]);
                    
                    // Обновляем панель данных
                    document.getElementById('wind-info').innerText = `${windData.speed} м/с, курс ${windData.deg}°`;
                    document.getElementById('info').innerHTML = `
                        <b>Шар в полете</b><br>
                        Координаты: ${newLat.toFixed(5)}, ${newLng.toFixed(5)}<br>
                        Ветер: ${windData.speed} м/с
                    `;
                }

                // Запуск анимации (раз в секунду)
                setInterval(updateBalloonPosition, 1000);

            } catch (err) {
                console.error("Ошибка:", err);
                document.getElementById('info').innerHTML = "<b style='color:red'>Критическая ошибка API</b>";
            }
        };
    </script>
</body>
</html>
